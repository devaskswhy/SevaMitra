# ──────────────────────────────────────────────
# SevaMitra API — Environment Variables
# Copy this file to .env and fill in real values
# ──────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/sevamitra?schema=public

# Redis connection string
REDIS_URL=redis://localhost:6379

# Server port
PORT=3001

# JWT secret for signing tokens (generate a strong random value)
JWT_SECRET=change-me-to-a-strong-random-secret

# Allowed CORS origin for Socket.IO and HTTP
SOCKET_CORS_ORIGIN=http://localhost:3000

# Runtime environment: development | production | test
NODE_ENV=development
