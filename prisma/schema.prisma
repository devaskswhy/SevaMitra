generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Volunteer {
  id               Int                @id @default(autoincrement())
  name             String
  phone            String             @unique
  email            String             @unique
  aadhaarHash      String
  age              Int
  gender           String
  languages        String             @default("")
  skills           String             @default("")
  certifications   String             @default("")
  homeState        String
  registeredAt     DateTime           @default(now())
  status           String             @default("ACTIVE")
  reliabilityScore Int                @default(0)
  completedShifts  Int                @default(0)
  assignments      Assignment[]
  incidents        Incident[]         @relation("IncidentVolunteers")
  sessions         VolunteerSession[]

  @@index([phone])
  @@index([status])
  @@index([registeredAt])
}

model Zone {
  id          Int        @id @default(autoincrement())
  name        String
  type        String
  coordinates String     @default("")
  maxCapacity Int
  currentLoad Int        @default(0)
  priority    String     @default("LOW")
  tasks       Task[]
  incidents   Incident[]

  @@index([type])
  @@index([priority])
}

model Task {
  id                Int          @id @default(autoincrement())
  title             String
  skillsRequired    String       @default("")
  zoneId            Int
  zone              Zone         @relation(fields: [zoneId], references: [id])
  estimatedDuration Int
  difficulty        Int
  minVolunteers     Int
  maxVolunteers     Int
  assignments       Assignment[]

  @@index([zoneId])
  @@index([difficulty])
}

model Assignment {
  id                Int       @id @default(autoincrement())
  volunteerId       Int
  volunteer         Volunteer @relation(fields: [volunteerId], references: [id])
  taskId            Int
  task              Task      @relation(fields: [taskId], references: [id])
  shiftId           Int
  shift             Shift     @relation(fields: [shiftId], references: [id])
  checkInTime       DateTime?
  checkOutTime      DateTime?
  performanceRating Int?
  createdAt         DateTime  @default(now())

  @@unique([volunteerId, taskId, shiftId])
  @@index([volunteerId])
  @@index([taskId])
  @@index([shiftId])
  @@index([createdAt])
}

model Incident {
  id                 Int         @id @default(autoincrement())
  zoneId             Int
  zone               Zone        @relation(fields: [zoneId], references: [id])
  reportedBy         String
  status             String      @default("ACTIVE")
  severity           Int
  type               String
  description        String
  resolvedAt         DateTime?
  createdAt          DateTime    @default(now())
  volunteersDeployed Volunteer[] @relation("IncidentVolunteers")

  @@index([zoneId])
  @@index([severity])
  @@index([type])
  @@index([resolvedAt])
  @@index([createdAt])
}

model Shift {
  id          Int          @id @default(autoincrement())
  startTime   DateTime
  endTime     DateTime
  assignments Assignment[]

  @@index([startTime])
  @@index([endTime])
}

model VolunteerSession {
  id          Int       @id @default(autoincrement())
  volunteerId Int
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id])
  otp         String
  otpExpiresAt DateTime
  token       String?   @unique
  isVerified  Boolean   @default(false)
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime

  @@index([volunteerId])
  @@index([token])
  @@index([createdAt])
}